{
  "name": "@joktec/http",
  "description": "JokTec - Http Client Service",
  "version": "0.2.16",
  "private": false,
  "license": "MIT",
  "author": "JokTec",
  "main": "dist/index",
  "types": "dist/index",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "keywords": [
    "http",
    "api",
    "axios"
  ],
  "scripts": {
    "clean": "rimraf -rf dist",
    "purge": "rimraf -rf dist node_modules",
    "prebuild": "yarn clean",
    "build": "nest build -p tsconfig.json",
    "prepublishOnly": "yarn build",
    "format": "prettier \"./src/**/*.ts\" --ignore-path ./.prettierignore --write",
    "lint": "eslint --fix \"./src/**/*.ts\"",
    "dep:upgrade": "ncu -p yarn -f /^@joktec*/ -u",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@joktec/core": "0.2.13",
    "@joktec/utils": "0.1.4",
    "axios": "^1.18.1",
    "axios-cookiejar-support": "7.0.0",
    "axios-curlirize": "~2.0.0",
    "axios-retry": "^4.5.0",
    "form-data": "^4.0.6",
    "http-cookie-agent": "^8.0.0",
    "http-proxy-agent": "^9.1.0",
    "https-proxy-agent": "^9.1.0",
    "lodash": "^4.18.1",
    "qs": "^6.15.2",
    "rxjs": "^7.8.2",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@types/axios-curlirize": "^1.3.6",
    "@types/form-data": "^2.5.2"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write --ignore-path ./.prettierignore",
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "jest": {
    "passWithNoTests": true,
    "preset": "ts-jest",
    "rootDir": "src",
    "transform": {
      "^.+\\.(t|s)s$": "ts-jest"
    },
    "coverageDirectory": "<rootDir>/../coverage/",
    "collectCoverageFrom": [
      "**/*.{ts,js}",
      "!**/index.ts",
      "!**/*.{d,enum}.ts"
    ],
    "moduleNameMapper": {
      "^axios-curlirize$": "<rootDir>/__mocks__/axios-curlirize.ts",
      "^http-proxy-agent$": "<rootDir>/__mocks__/http-proxy-agent.ts",
      "^https-proxy-agent$": "<rootDir>/__mocks__/https-proxy-agent.ts",
      "^slug$": "<rootDir>/../../../common/utils/src/__mocks__/slug.ts",
      "^uuid$": "<rootDir>/../../../common/utils/src/__mocks__/uuid.ts"
    }
  },
  "gitHead": "5c13d4ee8ca290e9f0f98482f014c818faf98e42"
}
