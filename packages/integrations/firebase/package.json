{
  "name": "@joktec/firebase",
  "description": "JokTec - Firebase Admin Service",
  "version": "0.2.16",
  "private": false,
  "license": "MIT",
  "author": "JokTec",
  "main": "dist/index",
  "types": "dist/index",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "keywords": [
    "firebase"
  ],
  "scripts": {
    "clean": "rimraf -rf dist",
    "purge": "rimraf -rf dist node_modules",
    "prebuild": "yarn clean",
    "build": "nest build -p tsconfig.json",
    "prepublishOnly": "yarn build",
    "format": "prettier \"./src/**/*.ts\" --ignore-path ./.prettierignore --write",
    "lint": "eslint --fix \"./src/**/*.ts\"",
    "dep:upgrade": "ncu -p yarn -u",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@joktec/core": "0.2.16",
    "@joktec/utils": "0.1.5",
    "firebase-admin": "^14.0.0",
    "lodash": "^4.18.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write --ignore-path ./.prettierignore",
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "jest": {
    "passWithNoTests": true,
    "preset": "ts-jest",
    "rootDir": "src",
    "transform": {
      "^.+\\.(t|s)s$": "ts-jest"
    },
    "coverageDirectory": "<rootDir>/../coverage/",
    "collectCoverageFrom": [
      "**/*.{ts,js}",
      "!**/index.ts",
      "!**/*.{d,enum}.ts"
    ],
    "moduleNameMapper": {
      "^firebase-admin/app$": "<rootDir>/__mocks__/firebase-admin-app.ts",
      "^firebase-admin/app-check$": "<rootDir>/__mocks__/firebase-admin-app-check.ts",
      "^firebase-admin/auth$": "<rootDir>/__mocks__/firebase-admin-auth.ts",
      "^firebase-admin/database$": "<rootDir>/__mocks__/firebase-admin-database.ts",
      "^firebase-admin/firestore$": "<rootDir>/__mocks__/firebase-admin-firestore.ts",
      "^firebase-admin/messaging$": "<rootDir>/__mocks__/firebase-admin-messaging.ts",
      "^firebase-admin/storage$": "<rootDir>/__mocks__/firebase-admin-storage.ts",
      "^slug$": "<rootDir>/../../../common/utils/src/__mocks__/slug.ts",
      "^uuid$": "<rootDir>/../../../common/utils/src/__mocks__/uuid.ts"
    }
  },
  "gitHead": "5c13d4ee8ca290e9f0f98482f014c818faf98e42"
}
