{
  "name": "@joktec/types",
  "description": "JokTec - Types",
  "version": "0.0.0",
  "author": "JokTec",
  "private": true,
  "license": "MIT",
  "files": ["dist", "bin"],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "clean": "rimraf -rf dist",
    "purge": "rimraf -rf dist node_modules",
    "format": "prettier \"./src/**/*.ts\" --ignore-path ./.prettierignore --write",
    "lint": "eslint --fix \"./src/**/*.ts\"",
    "prebuild": "rimraf dist",
    "dep:upgrade": "ncu -p yarn -f /^@joktec*/ -u",
    "build": "npx tsc -p tsconfig.json && node dist/main"
  },
  "dependencies": {
    "@joktec/alert": "^0.2.13",
    "@joktec/arango": "^0.2.13",
    "@joktec/bigquery": "^0.2.13",
    "@joktec/cacher": "^0.2.14",
    "@joktec/core": "^0.2.13",
    "@joktec/cron": "^0.2.17",
    "@joktec/elastic": "^0.2.16",
    "@joktec/file": "^0.2.13",
    "@joktec/firebase": "^0.2.13",
    "@joktec/http": "^0.2.16",
    "@joktec/kafka": "^0.2.13",
    "@joktec/mailer": "^0.2.13",
    "@joktec/mongo": "^0.2.32",
    "@joktec/mysql": "^0.2.17",
    "@joktec/notifier": "^0.2.13",
    "@joktec/rabbit": "^0.2.13",
    "@joktec/redcast": "^0.1.17",
    "@joktec/storage": "^0.2.15",
    "@joktec/sqs": "^0.1.16",
    "ts-json-schema-generator": "^2.9.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "lint-staged": {
    "*.ts": ["prettier --write --ignore-path ./.prettierignore", "eslint --fix"]
  },
  "jest": {
    "passWithNoTests": true,
    "preset": "ts-jest",
    "rootDir": "src",
    "transform": {
      "^.+\\.(t|s)s$": "ts-jest"
    },
    "coverageDirectory": "<rootDir>/../coverage/",
    "collectCoverageFrom": ["**/*.{ts,js}", "!**/index.ts", "!**/*.{d,enum}.ts"]
  }
}
