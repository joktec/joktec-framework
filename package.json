{
  "name": "joktec",
  "description": "JokTec - Monorepo with Lerna template",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "JokTec",
  "engines": {
    "node": ">=14"
  },
  "workspaces": ["packages/*/*", "apps/*"],
  "publishConfig": {
    "provenance": false
  },
  "keywords": ["microservices", "monorepo", "lerna", "nx"],
  "scripts": {
    "postinstall": "husky",
    "ls": "lerna ls -la && nx print-affected",
    "relp": "lerna run relp",
    "madge": "lerna run madge",
    "dev": "lerna run dev",
    "build": "lerna run build --concurrency 8",
    "serve": "lerna run serve",
    "test": "lerna run test",
    "test:cov": "lerna run test:cov",
    "test:e2e": "lerna run test:e2e",
    "format": "lerna run format",
    "lint": "lerna run lint",
    "clean": "lerna run clean",
    "purge": "lerna run purge && rimraf -rf ./node_modules",
    "dep:upgrade": "lerna run dep:upgrade",
    "graph": "nx affected:graph",
    "commit": "czg",
    "release": "lerna version",
    "publish:patch": "lerna publish patch --exact --no-private --yes",
    "publish:minor": "lerna publish minor --exact --no-private --yes",
    "publish:major": "lerna publish major --exact --no-private --yes",
    "deploy:dev": "lerna run deploy -- --ns joktec-develop --helm helm",
    "deploy:stag": "lerna run deploy -- --ns joktec-staging --helm helm",
    "deploy:prod": "lerna run deploy -- --ns joktec-production --helm helm",
    "ci": "bin/jenkin-ci.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "cz-git": "^1.13.1",
    "czg": "^1.13.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.7",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-mock": "^30.4.1",
    "lerna": "^9.0.7",
    "lerna-update-wizard": "^1.1.2",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "npm-check-updates": "^22.2.7",
    "nx": "^23.0.0",
    "nx-cloud": "^19.1.3",
    "nyc": "^18.0.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
